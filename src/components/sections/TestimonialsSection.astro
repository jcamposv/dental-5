---
import { testimonials } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-forest text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="font-display text-4xl sm:text-5xl font-bold mb-4">Lo que Dicen Nuestros Pacientes</h2>
      <p class="text-white/60 text-sm max-w-md mx-auto">Historias reales de pacientes que confían en nosotros para su salud dental.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
          <div class="flex gap-1 mb-4">
            {[...Array(t.rating)].map(() => (
              <svg class="w-4 h-4 text-terracotta" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-white/80 leading-relaxed mb-4">"{t.text}"</p>
          <p class="text-sm font-semibold text-white">{t.name}</p>
        </div>
      ))}
    </div>
  </div>
</section>
