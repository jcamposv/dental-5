---
import { siteConfig, footer } from "../../data/site";
const year = new Date().getFullYear();
---

<footer class="bg-forest text-white/80" id="contacto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="mb-4">
          <img src="/logo-center.png" alt="Crenter Dental" class="h-12 w-auto brightness-0 invert" />
        </div>
        <p class="text-sm leading-relaxed text-white/60">{footer.description}</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-display text-sm font-bold text-white uppercase tracking-wider mb-4">Enlaces</h4>
        <ul class="space-y-2">
          {footer.quickLinks.map((link) => (
            <li><a href={`#${link.toLowerCase()}`} class="text-sm text-white/60 hover:text-white transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display text-sm font-bold text-white uppercase tracking-wider mb-4">Servicios</h4>
        <ul class="space-y-2">
          {footer.services.map((service) => (
            <li><span class="text-sm text-white/60">{service}</span></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-sm font-bold text-white uppercase tracking-wider mb-4">Contacto</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            {footer.contact.address}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            {footer.contact.phone}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            {footer.contact.email}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {footer.contact.hours}
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/40">&copy; {year} {siteConfig.name}. Todos los derechos reservados.</p>
      <div class="flex items-center gap-4">
        {footer.socials.map((social) => (
          <a href={social.href} class="text-xs text-white/40 hover:text-white transition-colors">{social.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
