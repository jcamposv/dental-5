---
import { about, images } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-cream" id="nosotros">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Badge -->
    <div class="flex items-center gap-2 mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-terracotta"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-muted">{about.badge}</span>
    </div>

    <!-- Headline -->
    <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-dark leading-[1.15] max-w-3xl mb-14">
      {about.headline} <span class="italic font-normal text-olive">{about.headlineAccent}</span>
    </h2>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-5">
      <!-- Stats card -->
      <div class="bg-cream-dark rounded-2xl p-6 flex flex-col justify-between">
        <div>
          <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-olive" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Años de</p>
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Experiencia</p>
        </div>
        <p class="font-display text-5xl font-bold text-dark mt-4">{about.stats[0].value}</p>
      </div>

      <!-- Image 1 -->
      <div class="rounded-2xl overflow-hidden aspect-[4/5] md:aspect-auto">
        <img src={images.about[0]} alt="Consultorio dental" class="w-full h-full object-cover" loading="lazy"/>
      </div>

      <!-- Image 2 -->
      <div class="rounded-2xl overflow-hidden aspect-[4/5] md:aspect-auto">
        <img src={images.about[1]} alt="Tratamiento dental" class="w-full h-full object-cover" loading="lazy"/>
      </div>

      <!-- Feature + Stats -->
      <div class="flex flex-col gap-4">
        <!-- Feature card -->
        <div class="bg-terracotta/10 rounded-2xl p-5 flex-1">
          <h3 class="font-display text-lg font-bold text-dark italic mb-2">{about.features[0].title}</h3>
          <p class="text-xs text-muted leading-relaxed">{about.features[0].description}</p>
        </div>
        <!-- Patient count -->
        <div class="bg-cream-dark rounded-2xl p-5">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted mb-1">Pacientes Satisfechos</p>
          <p class="font-display text-4xl font-bold text-dark">{about.stats[1].value}</p>
        </div>
      </div>
    </div>
  </div>
</section>
